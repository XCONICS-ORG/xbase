# Shared Xbase env.
# Copy to env/.env for local development if needed.

FLAG_SHOW_BETA_FEATURE=false
APP_ENV=development
APP_WEB_PORT=3002
STORYBOOK_PORT=5002

# Optional production URL used by @xbase/seo.
PRODUCTION_URL=

# Bucket storage.
# BUCKET_PROVIDER can be linode, s3, or minio. Linode is the default.
BUCKET_PROVIDER=linode
BUCKET_REGION=in-maa-1
BUCKET_ACCESS_KEY_ID=replace-with-bucket-access-key
BUCKET_SECRET_ACCESS_KEY=replace-with-bucket-secret-key
BUCKET_NAME=replace-with-bucket-name
BUCKET_ENDPOINT=
BUCKET_PUBLIC_BASE_URL=
BUCKET_PROXY_SIGNED_URLS=false

# Google Maps.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_ID=replace-with-google-maps-map-id
GOOGLE_MAPS_SERVER_API_KEY=replace-with-google-routes-api-server-key
