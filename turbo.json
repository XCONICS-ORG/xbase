{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_ENV",
    "APP_WEB_PORT",
    "FLAG_SHOW_BETA_FEATURE",
    "PRODUCTION_URL",
    "STORYBOOK_PORT",
    "BUCKET_ACCESS_KEY_ID",
    "BUCKET_ENDPOINT",
    "BUCKET_NAME",
    "BUCKET_PROVIDER",
    "BUCKET_PROXY_SIGNED_URLS",
    "BUCKET_PUBLIC_BASE_URL",
    "BUCKET_REGION",
    "BUCKET_SECRET_ACCESS_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "env/**"],
      "outputs": [".next/**", "!.next/cache/**", "storybook-static/**"]
    },
    "//#check": {},
    "//#fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "translate": {
      "dependsOn": ["^translate"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
