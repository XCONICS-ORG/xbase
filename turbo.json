{
  "$schema": "https://v2-9-18.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_ENV",
    "APP_WEB_PORT",
    "FLAG_SHOW_BETA_FEATURE",
    "PRODUCTION_URL",
    "STORYBOOK_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "env/**"],
      "outputs": [".next/**", "!.next/cache/**", "storybook-static/**"]
    },
    "//#check": {},
    "//#fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "translate": {
      "dependsOn": ["^translate"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
