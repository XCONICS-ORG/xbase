{
  "extends": "@xbase/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@xbase/assets": ["../../packages/assets/index.ts"],
      "@xbase/assets/*": ["../../packages/assets/public/*"],
      "@xbase/design-system/*": ["../../packages/design-system/*"],
      "@xbase/env": ["../../packages/env/index.ts"],
      "@xbase/env/*": ["../../packages/env/*"],
      "@xbase/icons/*": ["../../packages/icons/*"],
      "@xbase/libs": ["../../packages/libs/index.ts"],
      "@xbase/libs/*": ["../../packages/libs/*"],
      "@xbase/types": ["../../packages/types/index.ts"],
      "@xbase/types/*": ["../../packages/types/*"]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "../../packages/design-system/types/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
