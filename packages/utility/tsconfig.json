{
  "extends": "@xbase/typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@xbase/icons": ["../icons/index.ts"],
      "@xbase/icons/*": ["../icons/*.ts"]
    },
    "strictNullChecks": true
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
