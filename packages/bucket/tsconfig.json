{
  "extends": "@xbase/typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@xbase/env": ["../env/index.ts"],
      "@xbase/env/*": ["../env/*.ts"],
      "@xbase/bucket/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
