{
  "extends": "@xbase/typescript-config/react-library.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@xbase/assets": ["../assets/index.ts"],
      "@xbase/assets/*": ["../assets/public/*"],
      "@xbase/design-system/*": ["./*"],
      "@xbase/icons": ["../icons/index.ts"],
      "@xbase/icons/*": ["../icons/*.ts"],
      "@xbase/libs": ["../libs/index.ts"],
      "@xbase/libs/*": ["../libs/*"],
      "@xbase/types": ["../types/index.ts"],
      "@xbase/types/*": ["../types/*"],
      "@xbase/bucket": ["../bucket/index.ts"],
      "@xbase/bucket/*": ["../bucket/*.ts"]
    },
    "strictNullChecks": true
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
