{
  "name": "xbase",
  "version": "0.0.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XCONICS-ORG/xbase.git"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@biomejs/biome": "2.5.1",
    "@xbase/typescript-config": "workspace:*",
    "picocolors": "^1.1.1",
    "turbo": "^2.9.18",
    "typescript": "^6",
    "ultracite": "7.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "bun --env-file=env/.env turbo build",
    "clean": "turbo run clean --filter=@xbase/web --filter=@xbase/storybook --filter=@xbase/assets --filter=@xbase/design-system --filter=@xbase/env --filter=@xbase/feature-flags --filter=@xbase/icons --filter=@xbase/internationalization --filter=@xbase/libs --filter=@xbase/seo --filter=@xbase/typescript-config --filter=@xbase/bucket --filter=@xbase/utility --filter=@xbase/constants --filter=@xbase/types",
    "clean:all": "bun run clean && rm -rf node_modules .turbo",
    "dev": "node scripts/project/dev.mjs",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "rename-project": "node scripts/project/rename.mjs",
    "storybook:sync": "node scripts/storybook/sync-stories.mjs sync",
    "typecheck": "bun --env-file=env/.env turbo typecheck",
    "bucket:config": "node scripts/bucket/config.mjs",
    "bucket:setup": "node scripts/bucket/setup.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "theme:backup": "node scripts/theme/index.mjs backup",
    "theme:list": "node scripts/theme/index.mjs list",
    "theme:restore": "node scripts/theme/index.mjs restore",
    "theme:restore:default": "node scripts/theme/index.mjs restore default-globals.css",
    "theme:restore:latest": "node scripts/theme/index.mjs restore --latest",
    "theme:tweakcn": "node scripts/theme/index.mjs backup pre-tweakcn && bunx shadcn@latest add https://tweakcn.com/r/themes/cmlm09qdq000004l7a6e9681h",
    "deps:check": "NO_UPDATE_NOTIFIER=1 bunx npm-check-updates --workspaces --root",
    "deps:bump": "NO_UPDATE_NOTIFIER=1 bunx npm-check-updates -u --workspaces --root && bun install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
