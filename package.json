{
  "name": "turtle",
  "version": "0.0.1",
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@biomejs/biome": "2.5.1",
    "@turtle/typescript-config": "workspace:*",
    "picocolors": "^1.1.1",
    "turbo": "^2.9.18",
    "typescript": "^6",
    "ultracite": "7.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "bun --env-file=env/.env turbo build",
    "clean": "turbo run clean --filter=@turtle/web --filter=@turtle/storybook --filter=@turtle/assets --filter=@turtle/design-system --filter=@turtle/env --filter=@turtle/feature-flags --filter=@turtle/icons --filter=@turtle/internationalization --filter=@turtle/libs --filter=@turtle/seo --filter=@turtle/typescript-config --filter=@turtle/utility",
    "clean:all": "bun run clean && rm -rf node_modules .turbo",
    "dev": "node scripts/dev.mjs",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "rename-project": "node scripts/rename-project.mjs",
    "storybook:sync": "node scripts/storybook-stories.mjs sync",
    "typecheck": "bun --env-file=env/.env turbo typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "theme:backup": "node scripts/theme.mjs backup",
    "theme:list": "node scripts/theme.mjs list",
    "theme:restore": "node scripts/theme.mjs restore",
    "theme:restore:default": "node scripts/theme.mjs restore default-globals.css",
    "theme:restore:latest": "node scripts/theme.mjs restore --latest",
    "theme:tweakcn": "node scripts/theme.mjs backup pre-tweakcn && bunx shadcn@latest add https://tweakcn.com/r/themes/cmlm09qdq000004l7a6e9681h",
    "deps:check": "NO_UPDATE_NOTIFIER=1 bunx npm-check-updates --workspaces --root",
    "deps:bump": "NO_UPDATE_NOTIFIER=1 bunx npm-check-updates -u --workspaces --root && bun install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
